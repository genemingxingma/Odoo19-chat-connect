<odoo>
    <record id="view_chat_connect_config_list" model="ir.ui.view">
        <field name="name">chat.connect.config.list</field>
        <field name="model">chat.connect.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
                <field name="default_source_lang"/>
                <field name="default_target_lang"/>
                <field name="default_translation_model"/>
                <field name="max_webhook_payload_kb" optional="hide"/>
                <field name="max_media_mb" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_chat_connect_config_form" model="ir.ui.view">
        <field name="name">chat.connect.config.form</field>
        <field name="model">chat.connect.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                            <field name="auto_create_conversation"/>
                            <field name="webhook_enforce_token"/>
                        </group>
                        <group string="Default Translation">
                            <field name="default_source_lang"/>
                            <field name="default_target_lang"/>
                            <field name="default_translation_endpoint"/>
                            <field name="default_translation_api_key" password="True"/>
                            <field name="default_translation_model"/>
                        </group>
                    </group>
                    <group string="Safety and Retention">
                        <field name="max_webhook_payload_kb"/>
                        <field name="max_media_mb"/>
                        <field name="media_link_ttl_hours"/>
                        <field name="log_retention_days"/>
                    </group>
                    <group>
                        <field name="note" placeholder="Configuration notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chat_connect_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">chat.connect.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
