<odoo>
    <record id="view_chat_connect_conversation_tree" model="ir.ui.view">
        <field name="name">chat.connect.conversation.tree</field>
        <field name="model">chat.connect.conversation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="account_id"/>
                <field name="external_conversation_id"/>
                <field name="external_visitor_name"/>
                <field name="state"/>
                <field name="mail_channel_id"/>
            </list>
        </field>
    </record>

    <record id="view_chat_connect_conversation_form" model="ir.ui.view">
        <field name="name">chat.connect.conversation.form</field>
        <field name="model">chat.connect.conversation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="account_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="external_conversation_id"/>
                            <field name="external_visitor_id"/>
                            <field name="external_visitor_name"/>
                            <field name="mail_channel_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Messages">
                            <field name="message_ids">
                                <list editable="bottom">
                                    <field name="direction"/>
                                    <field name="text"/>
                                    <field name="translated_text" readonly="1"/>
                                    <field name="state" readonly="1"/>
                                    <button name="action_send_outbound" type="object" string="Send" invisible="direction != 'outbound' or state == 'sent'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chat_connect_conversation" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">chat.connect.conversation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
