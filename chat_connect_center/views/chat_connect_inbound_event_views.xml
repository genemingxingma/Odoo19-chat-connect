<odoo>
    <record id="view_chat_connect_inbound_event_list" model="ir.ui.view">
        <field name="name">chat.connect.inbound.event.list</field>
        <field name="model">chat.connect.inbound.event</field>
        <field name="arch" type="xml">
            <list create="false" delete="false" edit="false" decoration-danger="state == 'permanent_failed'" decoration-warning="state == 'failed'" decoration-success="state == 'done'" decoration-muted="state == 'ignored'">
                <field name="event_timestamp"/>
                <field name="account_id"/>
                <field name="event_uid"/>
                <field name="external_message_id" optional="hide"/>
                <field name="state" widget="badge"/>
                <field name="retry_count" optional="show"/>
                <field name="next_retry_at" optional="hide"/>
                <field name="processed_at" optional="hide"/>
                <field name="message_id" optional="show"/>
                <button name="action_retry_manual" type="object" string="Retry" icon="fa-repeat" invisible="state not in ('failed', 'permanent_failed', 'ignored')"/>
            </list>
        </field>
    </record>

    <record id="view_chat_connect_inbound_event_form" model="ir.ui.view">
        <field name="name">chat.connect.inbound.event.form</field>
        <field name="model">chat.connect.inbound.event</field>
        <field name="arch" type="xml">
            <form create="false" delete="false" edit="false">
                <header>
                    <button name="action_retry_manual" type="object" string="Retry Processing" class="btn-primary" invisible="state not in ('failed', 'permanent_failed', 'ignored')"/>
                    <field name="state" widget="statusbar" statusbar_visible="queued,processing,done,failed,permanent_failed,ignored"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="account_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="event_uid"/>
                            <field name="external_message_id"/>
                            <field name="message_id"/>
                        </group>
                        <group>
                            <field name="event_timestamp"/>
                            <field name="processing_started_at"/>
                            <field name="processed_at"/>
                            <field name="retry_count"/>
                            <field name="max_retries"/>
                            <field name="next_retry_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw Payload"><field name="payload_json"/></page>
                        <page string="Error"><field name="error_message"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chat_connect_inbound_event" model="ir.actions.act_window">
        <field name="name">Inbound Queue</field>
        <field name="res_model">chat.connect.inbound.event</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
