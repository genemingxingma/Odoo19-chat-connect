<odoo>
    <record id="view_chat_connect_message_tree" model="ir.ui.view">
        <field name="name">chat.connect.message.list</field>
        <field name="model">chat.connect.message</field>
        <field name="arch" type="xml">
            <list create="false" delete="false" edit="false" decoration-danger="state in ('permanent_failed', 'uncertain')" decoration-warning="state == 'failed'" decoration-success="state in ('sent', 'received')">
                <field name="create_date"/>
                <field name="conversation_id"/>
                <field name="account_id" optional="show"/>
                <field name="direction" widget="badge"/>
                <field name="message_type"/>
                <field name="text"/>
                <field name="ai_generated" optional="show"/>
                <field name="state" widget="badge"/>
                <field name="retry_count" optional="hide"/>
                <field name="sent_at" optional="hide"/>
                <field name="external_message_id" optional="hide"/>
                <button name="action_retry_manual" type="object" string="Retry" icon="fa-repeat" invisible="direction != 'outbound' or state not in ('failed', 'permanent_failed', 'uncertain')" groups="chat_connect_center.group_chat_connect_manager"/>
            </list>
        </field>
    </record>

    <record id="view_chat_connect_message_form" model="ir.ui.view">
        <field name="name">chat.connect.message.form</field>
        <field name="model">chat.connect.message</field>
        <field name="arch" type="xml">
            <form create="false" delete="false" edit="false">
                <header>
                    <button name="action_retry_manual" type="object" string="Retry Delivery" class="btn-primary" invisible="direction != 'outbound' or state in ('sent', 'received', 'sending')" groups="chat_connect_center.group_chat_connect_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="queued,sending,received,sent,failed,permanent_failed,uncertain"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="conversation_id"/>
                            <field name="account_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="direction"/>
                            <field name="message_type"/>
                            <field name="ai_generated"/>
                        </group>
                        <group>
                            <field name="create_date"/>
                            <field name="last_attempt_at"/>
                            <field name="sent_at"/>
                            <field name="retry_count"/>
                            <field name="max_retries"/>
                            <field name="next_retry_at"/>
                        </group>
                    </group>
                    <group string="Content">
                        <field name="text"/>
                        <field name="translated_text"/>
                        <field name="delivered_text"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                    <group string="Provider Result">
                        <group>
                            <field name="external_event_id"/>
                            <field name="external_message_id"/>
                            <field name="provider_request_id"/>
                            <field name="provider_http_status"/>
                        </group>
                        <group>
                            <field name="mail_message_id"/>
                            <field name="media_id"/>
                            <field name="media_url"/>
                        </group>
                    </group>
                    <notebook groups="chat_connect_center.group_chat_connect_manager">
                        <page string="Raw Payload"><field name="payload_json"/></page>
                        <page string="Error"><field name="error_message"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_chat_connect_message" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">chat.connect.message</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
