<odoo>
    <record id="view_chat_connect_message_tree" model="ir.ui.view">
        <field name="name">chat.connect.message.tree</field>
        <field name="model">chat.connect.message</field>
        <field name="arch" type="xml">
            <list>
                <field name="conversation_id"/>
                <field name="account_id"/>
                <field name="direction"/>
                <field name="message_type"/>
                <field name="text"/>
                <field name="state"/>
                <field name="retry_count"/>
                <field name="external_message_id"/>
                <button name="action_send_outbound" type="object" string="Send" invisible="direction != 'outbound' or state == 'sent'"/>
                <button name="action_reset_draft" type="object" string="Reset" invisible="state != 'failed'"/>
            </list>
        </field>
    </record>

    <record id="view_chat_connect_message_form" model="ir.ui.view">
        <field name="name">chat.connect.message.form</field>
        <field name="model">chat.connect.message</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="conversation_id"/>
                            <field name="account_id" readonly="1"/>
                            <field name="direction"/>
                            <field name="message_type"/>
                            <field name="state"/>
                            <field name="retry_count"/>
                            <field name="max_retries"/>
                            <field name="next_retry_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="external_message_id" readonly="1"/>
                            <field name="mail_message_id" readonly="1"/>
                            <field name="media_id" readonly="1"/>
                            <field name="media_url"/>
                        </group>
                    </group>
                    <group>
                        <field name="text"/>
                        <field name="translated_text" readonly="1"/>
                        <field name="payload_json" readonly="1"/>
                        <field name="error_message" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_send_outbound" type="object" string="Send" class="btn-primary" invisible="direction != 'outbound' or state == 'sent'"/>
                    <button name="action_reset_draft" type="object" string="Reset" invisible="state != 'failed'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_chat_connect_message" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">chat.connect.message</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
