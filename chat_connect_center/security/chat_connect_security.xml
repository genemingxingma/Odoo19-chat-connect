<odoo>
    <data noupdate="1">
        <record id="group_chat_connect_user" model="res.groups">
            <field name="name">Chat Connect Operator</field>
        </record>

        <record id="group_chat_connect_manager" model="res.groups">
            <field name="name">Chat Connect Manager</field>
            <field name="implied_ids" eval="[(4, ref('chat_connect_center.group_chat_connect_user'))]"/>
        </record>

        <record id="rule_chat_connect_account_company" model="ir.rule">
            <field name="name">Chat Connect accounts by company</field>
            <field name="model_id" ref="model_chat_connect_account"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_chat_connect_conversation_company" model="ir.rule">
            <field name="name">Chat Connect conversations by company</field>
            <field name="model_id" ref="model_chat_connect_conversation"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_chat_connect_message_company" model="ir.rule">
            <field name="name">Chat Connect messages by company</field>
            <field name="model_id" ref="model_chat_connect_message"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_chat_connect_event_company" model="ir.rule">
            <field name="name">Chat Connect events by company</field>
            <field name="model_id" ref="model_chat_connect_inbound_event"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_chat_connect_media_company" model="ir.rule">
            <field name="name">Chat Connect media by company</field>
            <field name="model_id" ref="model_chat_connect_media"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_chat_connect_log_company" model="ir.rule">
            <field name="name">Chat Connect logs by company</field>
            <field name="model_id" ref="model_chat_connect_diagnostic_log"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_chat_connect_config_company" model="ir.rule">
            <field name="name">Chat Connect settings by company</field>
            <field name="model_id" ref="model_chat_connect_config"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_chat_connect_account_operator" model="ir.rule">
            <field name="name">Operators see assigned Chat Connect accounts</field>
            <field name="model_id" ref="model_chat_connect_account"/>
            <field name="groups" eval="[(4, ref('chat_connect_center.group_chat_connect_user'))]"/>
            <field name="domain_force">[('operator_user_ids', 'in', [user.id])]</field>
        </record>

        <record id="rule_chat_connect_account_manager" model="ir.rule">
            <field name="name">Managers see company Chat Connect accounts</field>
            <field name="model_id" ref="model_chat_connect_account"/>
            <field name="groups" eval="[(4, ref('chat_connect_center.group_chat_connect_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_chat_connect_conversation_operator" model="ir.rule">
            <field name="name">Operators see assigned Chat Connect conversations</field>
            <field name="model_id" ref="model_chat_connect_conversation"/>
            <field name="groups" eval="[(4, ref('chat_connect_center.group_chat_connect_user'))]"/>
            <field name="domain_force">[('account_id.operator_user_ids', 'in', [user.id])]</field>
        </record>

        <record id="rule_chat_connect_conversation_manager" model="ir.rule">
            <field name="name">Managers see company Chat Connect conversations</field>
            <field name="model_id" ref="model_chat_connect_conversation"/>
            <field name="groups" eval="[(4, ref('chat_connect_center.group_chat_connect_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_chat_connect_message_operator" model="ir.rule">
            <field name="name">Operators see assigned Chat Connect messages</field>
            <field name="model_id" ref="model_chat_connect_message"/>
            <field name="groups" eval="[(4, ref('chat_connect_center.group_chat_connect_user'))]"/>
            <field name="domain_force">[('account_id.operator_user_ids', 'in', [user.id])]</field>
        </record>

        <record id="rule_chat_connect_message_manager" model="ir.rule">
            <field name="name">Managers see company Chat Connect messages</field>
            <field name="model_id" ref="model_chat_connect_message"/>
            <field name="groups" eval="[(4, ref('chat_connect_center.group_chat_connect_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>

    <data>
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('chat_connect_center.group_chat_connect_manager'))]"/>
        </record>
    </data>
</odoo>
